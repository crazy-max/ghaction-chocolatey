{
  "name": "chocolatey-action",
  "description": "GitHub Action for Chocolatey, the package manager for Windows",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs --sourcemap --minify && yarn run license",
    "lint": "yarn run eslint",
    "format": "yarn run eslint:fix",
    "eslint": "eslint --max-warnings=0 .",
    "eslint:fix": "eslint --fix .",
    "license": "generate-license-file --input package.json --output dist/licenses.txt --overwrite --ci --no-spinner --eol lf",
    "all": "yarn run build && yarn run format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crazy-max/ghaction-chocolatey.git"
  },
  "keywords": [
    "actions",
    "chocolatey"
  ],
  "author": "CrazyMax",
  "license": "MIT",
  "packageManager": "yarn@4.12.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "generate-license-file": "^4.1.1",
    "globals": "^14.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
